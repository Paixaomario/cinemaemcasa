{
  "name": "cinemaemcasa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "e2e": "cypress run",
    "e2e:open": "cypress open",
    "e2e:run-headless": "cypress run --headless",
    "build:webos": "next build && node scripts/build-webos.js",
    "build:tizen": "node scripts/build-tizen.js",
    "build:roku": "mkdir -p dist && cd roku && zip -r ../dist/roku-app.zip . -x '.*'",
    "build:all": "npm run build && npm run build:webos",
    "webos:setup": "npx --package=@webos-tools/cli ares-setup-device",
    "webos:auth": "npx --package=@webos-tools/cli ares-novicom tv",
    "webos:install": "npx --package=@webos-tools/cli ares-install dist/*.ipk -d tv",
    "sync": "git add . && git commit -m \"Configuração atualizada: $(date +'%d/%m/%Y %H:%M:%S')\" && git push"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.39.7",
    "@vidstack/react": "^1.12.12",
    "lucide-react": "^0.474.0",
    "next": "15.5.18",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@webos-tools/cli": "^3.2.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.1.5",
    "@types/jest": "^29.5.11",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.18",
    "cypress": "^13.17.0",
    "dotenv": "^16.4.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "cookie": "^0.7.0",
    "postcss": "^8.5.10"
  }
}
